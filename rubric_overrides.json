        return result("negative", "fud_context", adjust_uncertainty=True, explanation="FUD context")
    
    # ACCURACY IMPROVEMENT: Hack/attack with community response
    # "hack" is negative, but "community rallies after hack" might be mixed
    if re.search(r"(hack|hacked|attack|breach).*(community|responds?|rallies?|recovers?)", text):
        # Still negative overall, but less severe
        return result("negative", "hack_with_response", adjust_uncertainty=True, explanation="hack with community response")
    if re.search(r"(community|responds?|rallies?).*(hack|hacked|attack|breach)", text):
