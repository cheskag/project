    has_edges_higher = 'edges higher' in text_lower or 'edged higher' in text_lower
    
    has_looks_cheap = 'looks cheap' in text_lower or ('cheap' in text_lower and any(ctx in text_lower for ctx in ['options', 'bitcoin', 'btc', 'ethereum', 'eth']))
    
    has_tax_break = 'tax break' in text_lower or 'treasury tax break' in text_lower
    
    has_dollar_weakness = 'dollar weakness' in text_lower or ('weakness' in text_lower and 'dollar' in text_lower)
    
    has_community_positive = any(pattern in text_lower for pattern in [
        'community rallies', 'community responded', 'responded by buying',
        'community support', 'community buying', 'buying the token',
        'en masse', 'community rallied'
    ])
    
    has_accumulation_strong = any(pattern in text_lower for pattern in [
        'eating up', 'at an unimaginable rate', 'unimaginable rate',
        'eating up btc', 'eating up bitcoin'
    ])
    
    has_valued_multiple = re.search(r'valued\s+\d+\.?\d*x', text_lower) or 'valued 1.29x' in text_lower
    
    has_last_call = 'last call' in text_lower or 'last call to' in text_lower
    
    has_nears_record = 'nears new record' in text_lower or 'nears record' in text_lower
    
    has_reclaim_positive = any(pattern in text_lower for pattern in [
        'reclaims $', 'reclaimed $', 'reclaiming $',
        'next stop', 'next all-time high', 'next ath'
    ])
    
    has_profit_by = 'profit by' in text_lower or 'profit of' in text_lower or 'in profit' in text_lower
    
    has_supply_rally = any(pattern in text_lower for pattern in [
        'supply is drying', 'supply drying', 'drying up fast',
        'rally followed', 'followed by', 'massive rally followed'
    ])
    
    has_growth_pattern = re.search(r'went from \d+', text_lower) or re.search(r'from \d+.*to \d+', text_lower)
    
    has_multiple_market_cap = re.search(r'\d+x\s+market cap', text_lower) or '5x market cap' in text_lower
    
    has_unprecedented = 'unprecedented growth' in text_lower or 'unprecedented' in text_lower
    
    has_high_valuation = re.search(r'\$?\d+[bm]?\s*valuation', text_lower) or '$500b valuation' in text_lower
    
    has_another_buy = 'another buy' in text_lower or 'another week, another buy' in text_lower
    
    has_surge_gain = any(pattern in text_lower for pattern in [
        'surges on', 'surged on', 'surges',
        'gaining ground', 'gained ground', 'gains ground',
        'chipping away', 'chipping away at'
    ])
    
    has_fueled = 'fueled a' in text_lower or 'fueled by' in text_lower
    
    has_tech_positive = any(pattern in text_lower for pattern in [
        'ai-driven', 'ai &', 'ai x crypto',
        'on-chain', 'onchain', 'on chain',
        'network hashrate rose', 'hashrate rose',
        'network hashrate', 'hashrate'
    ])
    
    has_scalability = any(pattern in text_lower for pattern in [
        'push solana', 'push', 'pushes', 'pushing',
        'bigger blocks', 'bigger block', 'blocks',
        'scalability', 'scalable', 'scaling'
    ])
    
    has_milestone_new = any(pattern in text_lower for pattern in [
        'surpass $1b', 'surpasses $', 'surpassed $',
        'lift borrowing', 'lifts', 'raising', 'raises',
        'borrowing cap', 'cap from'
    ])
    
    has_wall_street_favorite = "wall street's favorite" in text_lower or "wall street favorite" in text_lower
    
    # ============================================================================
    # APPLY ALL PATTERNS (Priority Order)
    # ============================================================================
    
    # ACCURACY IMPROVEMENT: Check for "new ath" / "all-time high" patterns (before generic positive)
    if re.search(r"(new|reached|hit|surpassed|breaks?|breaking).*(ath|all.time.high|all.time.high)", text_lower) and not re.search(r"(may|might|could|if|uncertain|delays?).*(ath|all.time.high)", text_lower):
        prelim_label = adjust_for_uncertainty('very_positive')
        return adjust_question_label(prelim_label)
    
    # ACCURACY IMPROVEMENT: Check for "institutional adoption" (before generic positive)
    if re.search(r"institutional\s+(adoption|interest|investment|inflow)", text_lower) and not re.search(r"(delays?|blocks?|bans?|rejects?).*institutional", text_lower):
        prelim_label = adjust_for_uncertainty('very_positive')
        return adjust_question_label(prelim_label)
    
    # ACCURACY IMPROVEMENT: Check for "breakthrough" (before generic positive)
    if re.search(r"(breakthrough|break.through|major\s+breakthrough)", text_lower) and not re.search(r"(fail|delays?|blocks?)", text_lower):
        prelim_label = adjust_for_uncertainty('positive')
        return adjust_question_label(prelim_label)
    
    # Very positive patterns
    prelim_label = None
    if (has_crypto_action or has_rips_positive or has_blasts_higher or has_zoom_higher or
        has_bull_run or has_accumulation_strong or has_fuel_positive or has_charge_positive or
        has_gov_shutdown_crypto or has_last_call or has_nears_record or has_reclaim_positive or
        has_supply_rally or has_growth_pattern or has_multiple_market_cap or has_unprecedented or
        has_high_valuation or has_surge_gain or
        has_price_prediction and prediction_positive or
        has_partnership or has_price_movement_positive or has_supply_positive):
        prelim_label = adjust_for_uncertainty('very_positive')
        return adjust_question_label(prelim_label)
    
    # Positive patterns
    if (has_v6_positive or has_crypto_slang or has_stacks_positive or has_stake_investment or
        has_uptime_positive or has_bitcoiners or has_validators_growth or has_stablecoin_growth or
        has_miner_positive or has_crypto_technical or has_innovation or has_meme_until or
        has_record or has_achievement or has_activity_positive or has_join_positive or
        has_non_event or has_edges_higher or has_looks_cheap or has_tax_break or
        has_dollar_weakness or has_community_positive or has_valued_multiple or
        has_profit_by or has_another_buy or has_fueled or has_tech_positive or
        has_scalability or has_milestone_new or has_technical_positive or
        has_price_prediction or has_institutional_mention or has_regulatory_approval or
        has_milestone or has_personal_positive or has_adoption_integration or has_wall_street_favorite):
        prelim_label = adjust_for_uncertainty('positive')
        return adjust_question_label(prelim_label)
    
    # Question handling
    is_question = '?' in text
    
    if is_question:
        rhetorical_positive = any(phrase in text_lower for phrase in [
            'going to the moon', 'to the moon', 'moon soon', 'ath incoming',
            'unstoppable', 'best investment', 'great opportunity', 'buying opportunity',
            'tremendous opportunity', 'life changing', 'done for me',
            'wen moon', 'wen lambo'
        ])
        rhetorical_negative = any(phrase in text_lower for phrase in [
            'going to zero', 'dead', 'scam', 'rug pull', 'crash', 'dump',
            'worst investment', 'bad idea', 'regret', 'fail'
        ])
        
        if not rhetorical_positive and not rhetorical_negative:
            has_sentiment = any(kw in text_lower for kw in [
                'crash', 'dump', 'pump', 'rally', 'bullish', 'bearish',
                'scam', 'hack', 'adoption', 'approval', 'success', 'failure',
                'buying opportunity', 'tremendous opportunity', 'etf', 'partnership',
                'price prediction', 'forecast', 'expected', 'price', 'trading',
                'staking', 'making money', 'yield', 'hodl', 'moon'
            ])
            if not has_sentiment:
                return 'neutral'
    
    # Default to neutral
    # Final normalization to ensure 3-class system (positive, neutral, negative)
    final_label = 'neutral'
    # Note: All returns above should already be normalized through adjust_for_uncertainty 
    # and adjust_question_label, but this ensures consistency
    if final_label in ("very_positive", "super_positive"):
        return "positive"
    elif final_label in ("very_negative", "super_negative"):
        return "negative"
    return final_label


# ---------------------------------------------------------------------------
# Label normalization helpers
# ---------------------------------------------------------------------------

LABEL_TO_USER = {
    "very_positive": "positive",  # Normalized to 3-class: very_positive → positive
    "very_negative": "negative",  # Normalized to 3-class: very_negative → negative
    "positive": "positive",
    "negative": "negative",
    "neutral": "neutral",
    "maybe": "maybe",
}

USER_TO_INTERNAL = {
    "positive": "positive",  # All positive labels (including very_positive) → positive
    "negative": "negative",  # All negative labels (including very_negative) → negative
    "neutral": "neutral",
    "maybe": "maybe",
}


def normalize_existing_label(label) -> str:
    if label is None or (isinstance(label, float) and pd.isna(label)):
        return ""

    label_str = str(label).strip().lower()
    if not label_str or label_str == "nan":
        return ""

    mapping = {
        # Normalize all positive variants to "positive" (3-class system)
        "very_positive": "positive",
        "very positive": "positive",
        "super_positive": "positive",
        "super positive": "positive",
        "extremely_positive": "positive",
        "extremely positive": "positive",
        # Normalize all negative variants to "negative" (3-class system)
        "very_negative": "negative",
        "very negative": "negative",
        "super_negative": "negative",
        "super negative": "negative",
        "extremely_negative": "negative",
        "extremely negative": "negative",
        # Standard 3-class labels
        "positive": "positive",
        "negative": "negative",
        "neutral": "neutral",
        "maybe": "maybe",
    }

    return mapping.get(label_str, label_str)


def to_internal_label(label: str) -> str:
    normalized = normalize_existing_label(label)
    return USER_TO_INTERNAL.get(normalized, normalized)


# ---------------------------------------------------------------------------
# File resolution helpers
# ---------------------------------------------------------------------------

def resolve_input_path(explicit: str | None) -> Path:
    if explicit:
        candidate = Path(explicit)
        if not candidate.exists():
            raise FileNotFoundError(f"Specified input file '{candidate}' does not exist.")
        return candidate

    candidates = sorted(
        (
            p
            for p in DATASETS_DIR.glob("crypto_articles_ALL_for_labeling_*.xlsx")
            if p.is_file() and "_labeled" not in p.stem and "BALANCED" not in p.stem
        ),
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )

    if not candidates:
        raise FileNotFoundError(
            "No unlabeled dataset files matching 'crypto_articles_ALL_for_labeling_*.xlsx' were found in 'data scraping\\Datasets'."
        )

    return candidates[0]


# ---------------------------------------------------------------------------
# Main entry point
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="Apply the crypto rubric (V7) and output user-format labels."
    )
    parser.add_argument(
        "--file",
        dest="file_path",
        help="Optional explicit path to the input dataset. Defaults to the most recent unlabeled export.",
    )
    parser.add_argument(
        "--output",
        dest="output_path",
        help="Optional custom output path. Defaults to '<input>_labeled_RUBRICS.xlsx'.",
    )
    parser.add_argument(
        "--compare-report",
        dest="compare_report",
        help="If provided, write a regression diff (rows where labels changed) to this path (CSV or XLSX).",
    )
    parser.add_argument(
        "--pos-weight-scale",
        dest="pos_weight_scale",
        type=float,
        default=1.0,
        help="Scale factor for positive conflict weights (default: 1.0).",
    )
    parser.add_argument(
        "--neg-weight-scale",
        dest="neg_weight_scale",
        type=float,
        default=1.0,
        help="Scale factor for negative conflict weights (default: 1.0).",
    )

    args = parser.parse_args()

    global POS_WEIGHT_SCALE, NEG_WEIGHT_SCALE
    POS_WEIGHT_SCALE = max(args.pos_weight_scale, 0.0)
    NEG_WEIGHT_SCALE = max(args.neg_weight_scale, 0.0)

    filepath = resolve_input_path(args.file_path)
    print(f"Using dataset file: {filepath}")
    if POS_WEIGHT_SCALE != 1.0 or NEG_WEIGHT_SCALE != 1.0:
        print(
            f"Weighted conflict scalers -> positive ×{POS_WEIGHT_SCALE:.2f}, negative ×{NEG_WEIGHT_SCALE:.2f}"
        )

    df = pd.read_excel(filepath)

    block_mask = pd.Series(False, index=df.index)
    for column in ("headline", "content"):
        if column in df.columns:
            lowered = df[column].fillna("").astype(str).str.lower()
            for pattern in ACCESS_BLOCK_PATTERNS:
                block_mask |= lowered.str.contains(pattern, regex=False)
    removed_block_rows = int(block_mask.sum())
    if removed_block_rows:
        df = df.loc[~block_mask].reset_index(drop=True)
        print(f"Removed {removed_block_rows} access-block/security placeholder rows.")

    # Normalize common column names
    if "content" not in df.columns:
        if "headline" in df.columns:
            df["content"] = df["headline"].astype(str)
        else:
            raise KeyError("Dataset must include a content/text column or a headline/title column")
    if "headline" not in df.columns:
        for alt in ("title", "subject", "heading"):
            if alt in df.columns:
                df = df.rename(columns={alt: "headline"})
                break

    if "sentiment_5class" not in df.columns and "sentimen_5class" in df.columns:
        df = df.rename(columns={"sentimen_5class": "sentiment_5class"})
    elif "sentiment_5class" in df.columns and "sentimen_5class" in df.columns:
        df = df.drop(columns=["sentimen_5class"])

    dedup_before = len(df)
    content_exists = "content" in df.columns
    headline_exists = "headline" in df.columns
    if content_exists and headline_exists:
        df = df.drop_duplicates(subset=["content", "headline"], keep="first")
    elif content_exists:
        df = df.drop_duplicates(subset=["content"], keep="first")
    elif headline_exists:
        df = df.drop_duplicates(subset=["headline"], keep="first")
    else:
        raise KeyError("Dataset must include at least a content/text or headline/title column")
    dedup_after = len(df)
    if dedup_after != dedup_before:
        print(f"Removed {dedup_before - dedup_after} duplicate rows based on content/headline")

    if "date_published" in df.columns:
        df["date_published"] = pd.to_datetime(df["date_published"], errors="coerce")
        now_ts = pd.Timestamp.utcnow().tz_localize(None)
        df.loc[df["date_published"] > now_ts, "date_published"] = now_ts

    if "sentiment_5class" not in df.columns:
        df["sentiment_5class"] = ""

    ai_col = "sentiment_5class"
    asset_col = "asset" if "asset" in df.columns else None

    if asset_col is None:
        asset_col = "asset"
        df[asset_col] = ""

    asset_reassignments = 0

    for idx in df.index:
        headline = str(df.loc[idx, "headline"]) if "headline" in df.columns else ""
        content = str(df.loc[idx, "content"]) if "content" in df.columns else ""
        existing_asset = df.loc[idx, asset_col]

        inferred_asset, mentions = infer_asset_label(headline, content, existing_asset)
        existing_clean = (str(existing_asset or "")).strip().upper()
        target_asset = (inferred_asset or existing_clean).upper()

        if target_asset != existing_clean:
            asset_reassignments += 1

        df.at[idx, asset_col] = target_asset

    print(f"Asset reassigned on {asset_reassignments}/{len(df)} rows.")

    original_user_labels = df[ai_col].fillna("").apply(normalize_existing_label)
    df["rubric_previous_label"] = original_user_labels

    print("=" * 80)
    print("RUBRICS LABELER (V7) - COMPLETE IMPLEMENTATION")
    print("Outputs user-format labels (super positive / super negative)")
    print("=" * 80)

    if "rubric_rule_id" not in df.columns:
        df["rubric_rule_id"] = None

    total_rows = len(df)
    relabeled = 0

    for idx in df.index:
        content = str(df.loc[idx, "content"]) if "content" in df.columns else ""
        headline = str(df.loc[idx, "headline"]) if "headline" in df.columns else ""
        asset = str(df.loc[idx, asset_col]) if asset_col else ""

        new_internal = crypt_sentiment_guide(content, headline, asset)
        rule_id = LAST_RULE_ID
        # Normalize to 3-class: very_positive/very_negative → positive/negative
        if new_internal == "very_positive":
            new_label = "positive"
        elif new_internal == "very_negative":
            new_label = "negative"
        else:
            new_label = LABEL_TO_USER.get(new_internal, new_internal)

        df.at[idx, "rubric_rule_id"] = rule_id

        old_raw = df.loc[idx, ai_col]
        old_label = original_user_labels.loc[idx]

        if new_label != old_label:
            df.at[idx, ai_col] = new_label
            relabeled += 1
        elif old_label and old_label != old_raw:
            df.at[idx, ai_col] = old_label

        if (idx + 1) % 1000 == 0:
            print(f"  Processed {idx + 1}/{total_rows} rows...")

    print(f"\nRelabeled: {relabeled}/{total_rows} rows")

    new_user_labels = df[ai_col].fillna("").apply(normalize_existing_label)
    comparison = pd.DataFrame(
        {
            "old_label": original_user_labels,
            "new_label": new_user_labels,
        }
    )
    comparison["changed"] = comparison["old_label"] != comparison["new_label"]
    changed_count = int(comparison["changed"].sum())
    changed_pct = (changed_count / total_rows) * 100 if total_rows else 0.0
    print(f"Label changes (old vs new): {changed_count}/{total_rows} ({changed_pct:.1f}%)")

    if changed_count:
        transitions = (
            comparison.loc[comparison["changed"]]
            .groupby(["old_label", "new_label"])
            .size()
            .sort_values(ascending=False)
        )
        print("Top label transitions:")
        for (old_lbl, new_lbl), count in transitions.head(10).items():
            old_disp = old_lbl or "<blank>"
            new_disp = new_lbl or "<blank>"
            pct = (count / changed_count) * 100
            print(f"  {old_disp} -> {new_disp}: {count} ({pct:.1f}%)")

        if args.compare_report:
            diff_df = df.loc[comparison["changed"]].copy()
            diff_df.insert(0, "row_index", diff_df.index)
            compare_columns = [
                col
                for col in (
                    "row_index",
                    "headline",
                    "content",
                    "asset",
                    "rubric_previous_label",
                    ai_col,
                    "rubric_rule_id",
                )
                if col in diff_df.columns
            ]
            export_df = diff_df[compare_columns]
            compare_path = Path(args.compare_report)
            if compare_path.suffix.lower() in (".xlsx", ".xls"):
                export_df.to_excel(compare_path, index=False)
            else:
                export_df.to_csv(compare_path, index=False)
            print(f"Regression diff saved to: {compare_path}")
    elif args.compare_report:
        print("No label changes detected; regression diff not written.")

    df = df.drop(columns=["sentimen_5class"], errors="ignore")

    output_path = (
        Path(args.output_path)
        if args.output_path
        else filepath.with_name(filepath.stem + "_labeled_RUBRICS.xlsx")
    )

    df.to_excel(output_path, index=False)

    print("\n" + "=" * 80)
    print("FINAL STATISTICS")
    print("=" * 80)

    ai_final = df[ai_col].fillna("")
    ai_final_labeled = (ai_final != "") & (ai_final != "maybe")
    print(f"Total rows: {len(df)}")
    print(f"AI labeled: {ai_final_labeled.sum()}")
    print("\nLabel Distribution:")

    display_order = ["super negative", "negative", "neutral", "positive", "super positive"]
    dist = ai_final[ai_final_labeled].value_counts()
    total = len(df)
    for label in display_order:
        count = dist.get(label, 0)
        pct = (count / total) * 100 if total else 0
        print(f"  {label}: {count} ({pct:.1f}%)")

    print("\n\nACCURACY COMPARISON (Rows 1-1007)")
    print("=" * 80)

    def normalize_for_compare(label):
        return to_internal_label(label)

    subset = df.iloc[: min(1007, len(df))]
    if "rubric_previous_label" in subset.columns:
        prev_labels_subset = subset["rubric_previous_label"].fillna("").apply(normalize_for_compare)
    else:
        prev_labels_subset = subset[ai_col].fillna("").apply(normalize_for_compare)
    new_subset = subset[ai_col].fillna("").apply(normalize_for_compare)
    agreements = (prev_labels_subset == new_subset) & (prev_labels_subset != "")
    agreement_rate = agreements.sum() / len(subset) * 100 if len(subset) else 100.0

    print(f"Agreement rate: {agreement_rate:.1f}% ({agreements.sum()}/{len(subset)})")
    print(f"Disagreements: {len(subset) - agreements.sum()}")

    v6_filepath = DATASETS_DIR / "crypto_articles_ALL_for_labeling_20251106_110726_labeled_FINAL_V6.xlsx"
    try:
        if v6_filepath.exists() and len(df) >= len(subset):
            df_old = pd.read_excel(v6_filepath)
            old_subset = df_old.iloc[: len(subset)]
            old_labels = old_subset[ai_col].fillna("").apply(normalize_for_compare)
            agreements_old = (prev_labels_subset == old_labels) & (prev_labels_subset != "")
            agreement_rate_old = agreements_old.sum() / len(subset) * 100
            print(f"\nPrevious (V6) agreement rate: {agreement_rate_old:.1f}%")
            print(f"Improvement: {agreement_rate - agreement_rate_old:+.1f}%")
    except Exception:
        pass

    if asset_col:
        print("\n\nDistribution by Asset:")
        for asset_value in sorted(df[asset_col].dropna().unique()):
            asset_df = df[df[asset_col] == asset_value]
            if asset_df.empty:
                continue
            print(f"\n{asset_value} ({len(asset_df)} articles):")
            asset_dist = asset_df[ai_col].value_counts()
            for label in display_order:
                count = asset_dist.get(label, 0)
                if count == 0:
                    continue
                pct = (count / len(asset_df)) * 100
                print(f"  {label}: {count} ({pct:.1f}%)")

    print(f"\nSaved to: {output_path}")


if __name__ == "__main__":
    main()

