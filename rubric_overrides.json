def crypt_sentiment_guide(text, headline="", asset=""):
    """Return the 3-class label (positive, neutral, negative). 
    Internal labels like very_positive/very_negative are normalized to positive/negative.
    Enhanced for maximum accuracy with context-aware pattern matching."""

    global LAST_RULE_ID
    LAST_RULE_ID = None

    if not text or pd.isna(text):
        return "neutral"
    
    text = str(text).strip()
    headline = str(headline or "")
    asset = str(asset or "")

    # ACCURACY IMPROVEMENT: Headline priority - headlines often more accurate than content
    # If headline exists and is substantial, prioritize it for sentiment detection
    context = MatchContext(text=text, headline=headline, asset=asset, explain=False)

    for handler in (
        handle_newsletter_rules,
        handle_keyword_overrides,
        handle_weighted_conflict_rules,
        handle_specific_phrase_rules,
        handle_question_neutral_blocklist,
    ):
        match = handler(context)
        if match:
            # Normalize to 3-class: very_positive/very_negative → positive/negative
            label = match.label
            if label == "very_positive":
                return "positive"
            elif label == "very_negative":
                return "negative"
            return label

    full_text = context.full_text
    text_lower = context.text_lower
    headline_lower = context.headline_lower
    asset_lower = context.asset_upper
    has_uncertainty = context.has_uncertainty
    is_question = context.is_question

    def adjust_for_uncertainty(label: str) -> str:
        """Local helper that normalizes to 3-class system."""
        if has_uncertainty and label in ("very_positive", "very_negative"):
            return "positive" if label == "very_positive" else "negative"
        # Normalize to 3-class: very_positive/very_negative → positive/negative
        if label == "very_positive":
            return "positive"
        elif label == "very_negative":
            return "negative"
        return label

    def adjust_question_label(default_label: str) -> str:
        """Ensure questions default to neutral unless clearly rhetorical."""
        if not is_question:
            return default_label
        # If question includes conflicting cues (pump OR dump) → neutral
        if " or " in text_lower:
            return "neutral"
        rhetorical_positive = any(
            kw in text_lower
            for kw in [
                "to the moon",
                "moon?",
                "moon!",
                "lambo",
                "ath",
                "pump?",
                "pump!",
                "bullish?",
                "bullish!",
                "going to the moon",
                "massive gain",
            ]
        )
        rhetorical_negative = any(
            kw in text_lower
            for kw in [
                "going to zero",
                "zero?",
                "dump?",
                "dump!",
                "crash?",
                "crash!",
                "dead?",
                "scam?",
            ]
        )
        if rhetorical_positive and not rhetorical_negative:
            return default_label
        if rhetorical_negative and not rhetorical_positive:
            return default_label if default_label in ("negative", "very_negative") else "very_negative"
        return "neutral"

    # `is_question` already computed via MatchContext

    # Newsletter/aggregator neutral overrides
    if headline_lower in NEUTRAL_EXACT_TITLES:
        return 'neutral'
    if any(phrase in text_lower for phrase in NEUTRAL_NEWSLETTER_PHRASES):
        return 'neutral'

    # Specific overrides before generic rules
    if "bitcoin's strongest month" in text_lower or "bitcoin strongest month" in text_lower or "strongest month of the year" in text_lower:
        return adjust_question_label(adjust_for_uncertainty("very_positive"))

    if "options expiry" in text_lower and ("price swings" in text_lower or "price swing" in text_lower):
        return adjust_question_label(adjust_for_uncertainty("negative"))

    if "launchpads are funding ideas" in text_lower or ("launchpads" in text_lower and "not products" in text_lower):
        return "neutral"

    if "may be bad for" in text_lower or "might be bad for" in text_lower or "bad for btc" in text_lower or "bad for bitcoin" in text_lower:
        return adjust_question_label(adjust_for_uncertainty("negative"))

    if "start taxing" in text_lower or "going to start taxing" in text_lower or "will start taxing" in text_lower or "going to tax" in text_lower or "taxing crypto" in text_lower or "tax crypto gains" in text_lower:
        return adjust_question_label("very_negative")

    if "fuels bitcoin etf dominance" in text_lower or ("fuels" in text_lower and "dominance" in text_lower and "bitcoin" in text_lower):
        return adjust_question_label(adjust_for_uncertainty("very_positive"))

    if "withdraws pro-crypto" in text_lower or ("withdraws" in text_lower and "pro-crypto" in text_lower):
