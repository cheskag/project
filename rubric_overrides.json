# ---------------------------------------------------------------------------
# Overrides
# ---------------------------------------------------------------------------

def _load_keyword_overrides() -> list[tuple[tuple[str, ...], str, str]]:
    try:
        data = json.loads(OVERRIDES_PATH.read_text(encoding="utf-8"))
    except FileNotFoundError:
        logger.debug("No override file found at %s", OVERRIDES_PATH)
        return []

    overrides: list[tuple[tuple[str, ...], str, str]] = []
    for entry in data:
        keywords = tuple(k.lower() for k in entry.get("keywords", []) if k)
        if not keywords:
            continue
        label = entry.get("label", "").strip().lower()
        if not label:
            continue
        rule_id = entry.get("id") or "override_" + "_".join(k.replace(" ", "-") for k in keywords)
        overrides.append((keywords, label, rule_id))
    return overrides


KEYWORD_OVERRIDES = _load_keyword_overrides()
LAST_RULE_ID: Optional[str] = None


# ---------------------------------------------------------------------------
# Helper utilities
# ---------------------------------------------------------------------------


def adjust_for_uncertainty(label: str, context: MatchContext) -> str:
    """Adjust label for uncertainty, and normalize to 3-class system."""
    if context.has_uncertainty and label in ("very_positive", "very_negative"):
        return "positive" if label == "very_positive" else "negative"
    # Normalize to 3-class: very_positive/very_negative → positive/negative
    if label == "very_positive":
        return "positive"
    elif label == "very_negative":
        return "negative"
    return label


def adjust_question_label(default_label: str, context: MatchContext) -> str:
    """Ensure questions default to neutral unless clearly rhetorical. Returns 3-class labels."""
    if not context.is_question:
        # Normalize to 3-class before returning
        if default_label == "very_positive":
            return "positive"
        elif default_label == "very_negative":
            return "negative"
        return default_label
    
    text_lower = context.text_lower
    
    if " or " in text_lower:
        return "neutral"
    
    rhetorical_positive = any(marker in text_lower for marker in RHETORICAL_POSITIVE_MARKERS)
    rhetorical_negative = any(marker in text_lower for marker in RHETORICAL_NEGATIVE_MARKERS)
    
    if rhetorical_positive and not rhetorical_negative:
        # Normalize to 3-class
        if default_label == "very_positive":
            return "positive"
        elif default_label == "very_negative":
            return "negative"
        return default_label
    if rhetorical_negative and not rhetorical_positive:
        # Normalize to 3-class: always return "negative" (not "very_negative")
        return "negative"
    
    return "neutral"


