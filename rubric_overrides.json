# Rule handlers
# ---------------------------------------------------------------------------


def handle_newsletter_rules(context: MatchContext) -> Optional[RuleMatch]:
    """Neutralise newsletters, promotional mailers and short texts."""
    if not context.text or len(context.text) < 5:
        return context.make_result(
            "neutral",
            "short_text",
            explanation="content shorter than 5 characters",
        )

    if context.headline_lower in NEUTRAL_EXACT_TITLES:
        return context.make_result(
            "neutral",
            "newsletter_exact_title",
            explanation="headline is a known neutral newsletter title",
        )

    if any(phrase in context.text_lower for phrase in NEUTRAL_NEWSLETTER_PHRASES):
        return context.make_result(
            "neutral",
            "newsletter_phrase",
            explanation="contains newsletter phrasing",
        )

    return None


def _find_signal_matches(text: str, definitions: Sequence[SignalDefinition]) -> list[tuple[SignalDefinition, str]]:
    matches: list[tuple[SignalDefinition, str]] = []
    for definition in definitions:
        for term in definition.terms:
            lowered = term.lower()
            if lowered and lowered in text:
                matches.append((definition, term))
                break
    return matches


def handle_weighted_conflict_rules(context: MatchContext) -> Optional[RuleMatch]:
    """Resolve mixed articles by scoring high-signal positive and negative cues."""

    text = context.text_lower
    if "zoom higher" in text:
        return None
    positive_hits = _find_signal_matches(text, POSITIVE_SIGNAL_DEFS)
    negative_hits = _find_signal_matches(text, NEGATIVE_SIGNAL_DEFS)

    if not positive_hits or not negative_hits:
        return None

    total_positive = sum(defn.weight * POS_WEIGHT_SCALE for defn, _ in positive_hits)
    total_negative = sum(abs(defn.weight) * NEG_WEIGHT_SCALE for defn, _ in negative_hits)
    net_score = total_positive - total_negative

    dominant = "positive" if total_positive >= total_negative else "negative"
    dominant_strength = total_positive if dominant == "positive" else total_negative

    if net_score >= 4:
        label = "very_positive"
    elif net_score >= 2:
        label = "positive"
    elif net_score <= -4:
        label = "very_negative"
    elif net_score <= -2:
        label = "negative"
    elif dominant == "negative" and dominant_strength >= 3:
        label = "negative"
    elif dominant == "positive" and dominant_strength >= 3:
        label = "positive"
    else:
        label = "neutral"

    positive_terms = ", ".join(term for _, term in positive_hits)
    negative_terms = ", ".join(term for _, term in negative_hits)
    explanation = (
        f"Weighted signals conflict; positives ({positive_terms}) vs negatives ({negative_terms}); net={net_score:.1f}"
    )

    return context.make_result(
        label,
        "weighted_signal_conflict",
        explanation=explanation,
        adjust_uncertainty=True,
        apply_question_logic=True,
        weight=net_score,
    )


def handle_specific_phrase_rules(context: MatchContext) -> Optional[RuleMatch]:
    """Handle high-signal phrase overrides before generic pattern matching. Enhanced for maximum accuracy."""
    text = context.text_lower
    headline = context.headline_lower
    full_text = context.full_text.lower()

    def result(label: str, rule_id: str, *, adjust_uncertainty: bool = False, question_logic: bool = True, neutral_if_question: bool = False, explanation: str = "") -> RuleMatch:
        return context.make_result(
            label,
            rule_id,
            adjust_uncertainty=adjust_uncertainty,
            apply_question_logic=question_logic,
            neutral_if_question=neutral_if_question,
            explanation=explanation or rule_id,
        )

    # ACCURACY IMPROVEMENT: PRIORITY - "buying opportunity" (very positive, check early)
    # "tremendous buying opportunity" / "buying opportunity" → very positive/positive
    if re.search(r"(tremendous|great|excellent|good|attractive)\s+(buying\s+)?opportunity", text, re.IGNORECASE):
        return result("very_positive", "buying_opportunity", adjust_uncertainty=True, explanation="buying opportunity (very positive)")
    if re.search(r"buying\s+opportunity", text, re.IGNORECASE):
        return result("positive", "buying_opportunity_generic", adjust_uncertainty=True, explanation="buying opportunity")

    # ACCURACY IMPROVEMENT: Context-aware negation detection
    # "not bullish", "not positive", "not optimistic" → negative
    negation_patterns = [
        (r"not\s+(bullish|positive|optimistic|good|great|excited)", "negative", "negation_positive"),
        (r"no\s+(bullish|positive|optimistic|good|great)", "negative", "negation_positive"),
        (r"isn['']t\s+(bullish|positive|optimistic|good)", "negative", "negation_positive"),
        (r"aren['']t\s+(bullish|positive|optimistic)", "negative", "negation_positive"),
        (r"not\s+(bearish|negative|pessimistic|bad|worried)", "positive", "negation_negative"),
        (r"no\s+(bearish|negative|pessimistic|bad)", "positive", "negation_negative"),
    ]
    for pattern, label, rule_id in negation_patterns:
        if re.search(pattern, text):
            return result(label, rule_id, adjust_uncertainty=True, explanation=f"negation detected: {pattern}")

    # ACCURACY IMPROVEMENT: Context-aware "bullish", "pump", "rally" detection
    # "bullish bets unraveled" → negative (not positive!) - statement overrides question
    if re.search(r"bullish.*(unravel|fail|collapse|crash|dump|fade|reject)", text, re.IGNORECASE):
        return result("negative", "bullish_unraveled", adjust_uncertainty=False, explanation="bullish context reversed (statement overrides question)")
    if re.search(r"(pump\s+and\s+dump|pump.*dump|dump.*pump)", text):
        return result("negative", "pump_and_dump", adjust_uncertainty=True, explanation="pump and dump scheme")
    if re.search(r"rally.*(fade|fail|reject|collapse|end)", text):
        return result("negative", "rally_fades", adjust_uncertainty=True, explanation="rally fading")
    if re.search(r"(pump|rally).*over", text):
        return result("negative", "pump_rally_over", adjust_uncertainty=True, explanation="pump/rally ended")
    
    # ACCURACY IMPROVEMENT: Catch "unraveled" standalone (not just with bullish)
    # "Bullish bets unraveled" → negative (statement of fact, even if question follows)
    if re.search(r"\b(unraveled|unravel|unraveling)\b", text, re.IGNORECASE):
        # If there's a clear negative statement, prioritize it over questions
        return result("negative", "unraveled_standalone", adjust_uncertainty=False, explanation="things unraveling (statement overrides question)")
    
    # ACCURACY IMPROVEMENT: Catch "corrections" - especially "major corrections"
    # "Expect major BTC corrections" → negative (statement, not question)
    if re.search(r"(major\s+)?(btc|bitcoin|price|market)\s+corrections?", text, re.IGNORECASE):
        return result("negative", "corrections_detected", adjust_uncertainty=False, explanation="price corrections (statement)")
    if re.search(r"expect.*(major\s+)?(btc|bitcoin|price|market)?\s*corrections?", text, re.IGNORECASE):
        return result("negative", "expected_corrections", adjust_uncertainty=False, explanation="expected corrections (statement)")
    
    # ACCURACY IMPROVEMENT: Catch "resistance" / "faces resistance" (negative for price)
    if re.search(r"(faces?|facing)\s+resistance", text, re.IGNORECASE):
        return result("negative", "faces_resistance", adjust_uncertainty=True, explanation="price facing resistance")
    if re.search(r"resistance\s+at\s+\$", text, re.IGNORECASE):
        return result("negative", "resistance_level", adjust_uncertainty=True, explanation="price resistance level")
    
    # ACCURACY IMPROVEMENT: Catch "volatility cut" / "gains erased" / "reversal"
    if re.search(r"(volatility|volatile).*(cut|erased|reversal)", text, re.IGNORECASE):
        return result("negative", "volatility_cut", adjust_uncertainty=True, explanation="volatility cutting gains")
    if re.search(r"(gains?|momentum).*(erased|cut|reversal|reversed)", text, re.IGNORECASE):
        return result("negative", "gains_erased", adjust_uncertainty=True, explanation="gains erased")
    if re.search(r"(swift|late.session)\s+reversal", text, re.IGNORECASE):
        return result("negative", "swift_reversal", adjust_uncertainty=True, explanation="swift reversal")
    
    # ACCURACY IMPROVEMENT: Catch "risky" / "too risky" / "dangerous"
    if re.search(r"(too\s+)?risky|dangerous|at\s+risk|high\s+risk", text, re.IGNORECASE):
        return result("negative", "risky_dangerous", adjust_uncertainty=True, explanation="risk warnings")
    
    # ACCURACY IMPROVEMENT: Catch "FUD" / "FUD posts"
    if re.search(r"\bfud\b|\bfud\s+posts?\b", text, re.IGNORECASE):
        return result("negative", "fud_detected", adjust_uncertainty=True, explanation="FUD detected")
    
    # ACCURACY IMPROVEMENT: Catch "potential scam" / "scam or nah" / questions about scams
    # Questions about scams should be neutral (uncertainty), but statements should be negative
    if re.search(r"scam\s+(or|nah|\?)", text, re.IGNORECASE) or re.search(r"(potential|possible|likely)\s+scam\s+(or|nah|\?)", text, re.IGNORECASE):
        # Questions are uncertain - should be neutral
        return result("neutral", "scam_question", adjust_uncertainty=True, neutral_if_question=True, explanation="scam question (uncertain)")
    if re.search(r"(potential|possible|likely)\s+scam(?!\s+(or|nah|\?))", text, re.IGNORECASE):
        # Statement about potential scam (not a question) - negative
        return result("negative", "potential_scam", adjust_uncertainty=True, explanation="potential scam statement")
    
    # ACCURACY IMPROVEMENT: Catch "rug pull" in questions
    # Questions about rug pulls should be neutral (uncertainty), not negative
    if re.search(r"(how\s+does|does|is|are).*(rug\s+pull|anti.rug)", text, re.IGNORECASE):
        return result("neutral", "rug_pull_question", adjust_uncertainty=True, neutral_if_question=True, explanation="rug pull question (uncertain)")
    
    # ACCURACY IMPROVEMENT: Mixed sentiment - negative should win if corrections/reversals present
    # "corrections before new highs" → negative (corrections are more immediate/negative)
    if re.search(r"(corrections?|dips?|pullbacks?).*(before|prior|ahead)", text, re.IGNORECASE):
        return result("negative", "corrections_before", adjust_uncertainty=True, explanation="corrections before positive event")
    if re.search(r"(expect|predict).*(corrections?|dips?|pullbacks?)", text, re.IGNORECASE):
        return result("negative", "expected_corrections", adjust_uncertainty=True, explanation="expected corrections")
    
    # ACCURACY IMPROVEMENT: "wiped out" / "billion wiped out" - very negative
    if re.search(r"(wiped\s+out|billion.*wiped|trillion.*wiped)", text, re.IGNORECASE):
        return result("very_negative", "wiped_out", adjust_uncertainty=False, explanation="massive losses wiped out")
    
    # ACCURACY IMPROVEMENT: Positive headline but negative content (reversal, resistance, volatility)
    # "XLM Surges 7% Before Swift Reversal" → negative (reversal is the key point)
    if re.search(r"(surges?|rallies?|jumps?|pumps?).*(before|but|then|however).*(reversal|resistance|volatility|cut|erased|selloff)", text, re.IGNORECASE):
        return result("negative", "positive_but_reversal", adjust_uncertainty=True, explanation="positive start but negative reversal")
    if re.search(r"(rallies?|surges?).*(faces?|facing).*resistance", text, re.IGNORECASE):
        return result("negative", "rally_faces_resistance", adjust_uncertainty=True, explanation="rally facing resistance")
    
    # ACCURACY IMPROVEMENT: "FUD posts" / "to all the FUD" - negative context
