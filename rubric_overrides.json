@dataclass(slots=True)
class RuleMatch:
    """The result of a single rule evaluation."""

    label: str
    rule_id: str
    explanation: str = ""
    adjustments: tuple[str, ...] = ()
    weight: float = 0.0


@dataclass(slots=True)
class MatchContext:
    """Rich pre-computed view of the text being labelled."""

    text: str
    headline: str
    asset: str
    explain: bool = False
    rule_log: list[RuleMatch] = field(default_factory=list)
    full_text: str = field(init=False)
    text_lower: str = field(init=False)
    headline_lower: str = field(init=False)
    asset_upper: str = field(init=False)
    is_question: bool = field(init=False)
    has_uncertainty: bool = field(init=False)

    def __post_init__(self) -> None:
        original_text = str(self.text or "").strip()
        original_headline = str(self.headline or "").strip()

        def normalize(s: str) -> str:
            return (
                s.replace("’", "'")
                .replace("‘", "'")
                .replace("“", '"')
                .replace("”", '"')
                .replace("–", "-")
                .replace("—", "-")
            )

        self.text = normalize(original_text)
        self.headline = normalize(original_headline)
        self.asset = str(self.asset or "").strip()

        combined = f"{self.headline} {self.text}".strip() if self.headline else self.text
        normalized_combined = normalize(combined)
        self.full_text = normalized_combined
        self.text_lower = normalized_combined.lower()
        self.headline_lower = self.headline.lower()
        self.asset_upper = self.asset.upper()
        self.is_question = "?" in combined
        self.has_uncertainty = any(marker in self.text_lower for marker in UNCERTAINTY_MARKERS)

    def record(self, match: RuleMatch) -> None:
        if self.explain:
            self.rule_log.append(match)

    def make_result(
        self,
        label: str,
        rule_id: str,
        *,
        adjust_uncertainty: bool = False,
        apply_question_logic: bool = False,
        neutral_if_question: bool = False,
        explanation: str = "",
        weight: float = 0.0,
    ) -> RuleMatch:
        """Return a RuleMatch after applying optional adjustments."""
        computed_label = label
        adjustments: list[str] = []

        if adjust_uncertainty:
            computed_label = adjust_for_uncertainty(computed_label, self)
            adjustments.append("uncertainty")

        if neutral_if_question and self.is_question:
            computed_label = "neutral"
            adjustments.append("neutralised_question")
        elif apply_question_logic:
            computed_label = adjust_question_label(computed_label, self)
            adjustments.append("question_logic")

        match = RuleMatch(
            label=computed_label,
            rule_id=rule_id,
            explanation=explanation or rule_id,
            adjustments=tuple(adjustments),
            weight=weight,
        )
        global LAST_RULE_ID
        LAST_RULE_ID = rule_id
        self.record(match)
        return match


@dataclass(frozen=True, slots=True)
class SignalDefinition:
    """Weighted sentiment signal detected via keyword groups."""

    rule_id: str
    terms: tuple[str, ...]
    weight: float
    description: str = ""


