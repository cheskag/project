def handle_keyword_overrides(context: MatchContext) -> Optional[RuleMatch]:
    """Apply rubric keyword overrides loaded from JSON configuration."""
    global LAST_RULE_ID
    for keywords, override_label, rule_id in KEYWORD_OVERRIDES:
        if all(keyword in context.text_lower for keyword in keywords):
            if "zoom higher" in context.text_lower and override_label in ("negative", "neutral"):
                continue
            if "wiped out" in context.text_lower and override_label == "negative":
                override_label = "negative"  # Map to 3-class: negative (not very_negative)
            LAST_RULE_ID = rule_id
            if override_label in ("neutral", "maybe"):
                return context.make_result(override_label, rule_id, explanation=f"override -> {override_label}")
            adjusted = adjust_for_uncertainty(override_label, context)
            adjusted = adjust_question_label(adjusted, context)
            # Normalize to 3-class system: very_positive/very_negative → positive/negative
            if adjusted == "very_positive":
                adjusted = "positive"
            elif adjusted == "very_negative":
                adjusted = "negative"
            return context.make_result(adjusted, rule_id, explanation=f"override -> {override_label}")
    return None


def handle_question_neutral_blocklist(context: MatchContext) -> Optional[RuleMatch]:
    """Neutralise common question forms that should be informational."""
    if not context.is_question:
        return None

    neutral_question_phrases = (
        "what's the one crypto you're hodling",
        "is there a way to get free nft",
        "what the government shutdown means",
        "what the government shutdown",
        "how does anti-rug pull work",
        "how i can sale an nft",
        "virtual visa cards",
        "how to keep a small defi investment safe",
        'are "no account" dexs',
        "do pump-signal groups",
        "state of crypto: what happens to crypto if government shutdown lingers",
    )
    if context.text_lower.strip() == "meme cryptocurrencies":
        return context.make_result("neutral", "question_neutral_blocklist", explanation="question blocklist neutralisation")
    if "potential scam or nah" in context.text_lower:
        return context.make_result("negative", "question_potential_scam", apply_question_logic=True)
    if "best way" in context.text_lower and "recur buy" in context.text_lower:
        return context.make_result("neutral", "question_best_way_recur_buy", explanation="informational recurring buy question")
    if any(phrase in context.text_lower for phrase in neutral_question_phrases):
        return context.make_result("neutral", "question_neutral_blocklist", explanation="question blocklist neutralisation")
    return None


def handle_generic_pattern_blocks(context: MatchContext) -> Optional[RuleMatch]:
    """Evaluate the large library of positive/negative crypto heuristics."""

    text = context.text_lower
    is_question = context.is_question

    def commit(
        label: str,
        rule_id: str,
        *,
        adjust_uncertainty: bool = False,
        apply_question_logic: bool = False,
        neutral_if_question: bool = False,
        explanation: str = "",
    ) -> RuleMatch:
        match = context.make_result(
            label,
            rule_id,
            adjust_uncertainty=adjust_uncertainty,
            apply_question_logic=apply_question_logic,
            neutral_if_question=neutral_if_question,
            explanation=explanation or rule_id,
        )
        return match

